# Required in production (DEBUG=false)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/callback
SESSION_SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DISCORD_BOT_TOKEN=   # Optional: needed for Discord server import

# Set to "true" for local development without Discord OAuth
DEBUG=true

# Database URL — defaults to SQLite if not set
# DATABASE_URL=postgresql://user:pass@localhost:5432/sts

# CORS — comma-separated origins, defaults to http://localhost:5173
# ALLOWED_ORIGINS=https://sts.example.com
